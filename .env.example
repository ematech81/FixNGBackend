# ── App ───────────────────────────────────────────────────────────────────────
PORT=3000
APP_KEY=

# ── MongoDB ───────────────────────────────────────────────────────────────────
MONGODB_URI=

# ── JWT ───────────────────────────────────────────────────────────────────────
JWT_SECRET=
JWT_EXPIRES_IN=30d

# ── Kora Pay ──────────────────────────────────────────────────────────────────
KORAPAY_PUBLIC_KEY=pk_live_...
KORAPAY_SECRET_KEY=sk_live_...
KORAPAY_WEBHOOK_SECRET=

# ── Kora Pay pricing (NGN) ────────────────────────────────────────────────────
KORAPAY_PRICE_MONTHLY=5000
KORAPAY_PRICE_QUARTERLY=13500
KORAPAY_PRICE_YEARLY=48000

# ── Subscription lifecycle ────────────────────────────────────────────────────
SUB_TRIAL_DAYS=7
SUB_GRACE_DAYS=3
SUB_REFUND_WINDOW_HOURS=48

# ── Cloudinary ────────────────────────────────────────────────────────────────
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ── BulkSMS Nigeria (OTP delivery) ───────────────────────────────────────────
BULKSMS_API_TOKEN=
BULKSMS_SENDER_ID=FixNG
BULKSMS_BASE_URL=https://www.bulksmsnigeria.com/api/v2

# ── Flutterwave (KEEP for 30-day webhook catch window — do not delete yet) ────
FLW_SECRET_KEY=
FLW_WEBHOOK_HASH=
